// =============================================
// Custom Styles for Gaofeicm Blog
// =============================================

// ---------------------------------------------------------------
// CSS Variables Override
// ---------------------------------------------------------------
:root {
  --body-bg-color: #eee;
  --content-bg-color: #fff;
  --card-bg-color: #f5f5f5;
  --text-color: #555;
  --link-color: #555;
  --link-hover-color: #222;
  --brand-color: #fff;
  --brand-hover-color: #fff;
  --table-row-odd-bg-color: #f9f9f9;
  --table-row-hover-bg-color: #f5f5f5;
  --menu-item-bg-color: #f5f5f5;
}

// ---------------------------------------------------------------
// Header Band
// ---------------------------------------------------------------
.headband {
  background: #222;
  height: 3px;
}

// ---------------------------------------------------------------
// Site Title Styling
// ---------------------------------------------------------------
.site-title {
  font-family: 'Lato', "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 1.375em;
  font-weight: normal;
}

.site-subtitle {
  color: #ddd;
  font-size: 0.8125em;
  margin: 10px 0;
}

// ---------------------------------------------------------------
// Menu Styling
// ---------------------------------------------------------------
.menu {
  margin-top: 20px;
  padding-left: 0;
  text-align: center;
}

.menu-item {
  display: inline-block;
  list-style: none;
  margin: 0 10px;
}

.menu-item a {
  border-bottom: 0;
  display: block;
  font-size: 0.8125em;
  transition: all 0.2s ease-in-out;
}

.menu-item .fa {
  margin-right: 8px;
}

.menu-item-active a,
.menu .menu-item a:hover {
  background: var(--menu-item-bg-color);
}

// Mobile responsive menu
@media (max-width: 767px) {
  .menu-item {
    display: block;
    margin-top: 10px;
  }
  .menu-item.menu-item-search {
    display: none;
  }
}

// ---------------------------------------------------------------
// Sidebar Styling
// ---------------------------------------------------------------
.sidebar {
  background: var(--content-bg-color);
}

.sidebar-inner {
  padding: 20px 0;
}

.site-author {
  text-align: center;
  margin-bottom: 20px;
}

.site-author-image {
  border-radius: 50%;
  display: block;
  margin: 0 auto;
}

.site-author-name {
  margin: 10px 0 0;
  font-weight: bold;
}

.site-description {
  margin: 5px 0 0;
  font-size: 0.8125em;
  color: var(--text-color);
}

.links-of-author {
  margin-top: 20px;
  text-align: center;
}

.links-of-author-item {
  display: inline-block;
  margin: 0 10px;
}

.links-of-author-item a {
  border-bottom: none;
  color: var(--text-color);
}

.links-of-author-item a:hover {
  color: var(--link-hover-color);
}

// ---------------------------------------------------------------
// Post Styling
// ---------------------------------------------------------------
.post {
  margin-bottom: 40px;
}

.post-header {
  margin-bottom: 20px;
}

.post-title {
  font-size: 1.5em;
  margin: 0;
}

.post-title a {
  color: var(--text-color);
  border-bottom: none;
}

.post-title a:hover {
  color: var(--link-hover-color);
}

.post-meta {
  color: #999;
  font-size: 0.8125em;
  margin-top: 10px;
}

.post-meta-item {
  margin-right: 15px;
}

.post-meta-item .fa {
  margin-right: 5px;
}

.post-body {
  line-height: 1.8;
}

.post-body h1,
.post-body h2,
.post-body h3,
.post-body h4,
.post-body h5,
.post-body h6 {
  margin-top: 20px;
  margin-bottom: 15px;
}

.post-body p {
  margin: 0 0 20px 0;
}

.post-body img {
  display: block;
  margin: 20px auto;
  max-width: 100%;
  box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
}

.post-body blockquote {
  border-left: 4px solid #ddd;
  color: #666;
  margin: 20px 0;
  padding: 0 15px;
}

.post-body pre,
.post-body code {
  font-family: Consolas, Monaco, 'Andale Mono', monospace;
}

.post-body pre {
  background: #f7f7f7;
  padding: 15px;
  overflow: auto;
  border-radius: 4px;
}

// ---------------------------------------------------------------
// Pagination
// ---------------------------------------------------------------
.pagination {
  border-top: 1px solid #eee;
  margin: 60px 0 0;
  text-align: center;
}

.pagination .prev,
.pagination .next,
.pagination .page-number {
  border-bottom: 0;
  border-top: 1px solid #eee;
  display: inline-block;
  margin: 0 10px;
  padding: 10px 15px;
  transition: all 0.2s ease-in-out;
}

.pagination .prev:hover,
.pagination .next:hover,
.pagination .page-number:hover {
  border-top-color: #222;
}

.pagination .page-number.current {
  background: #ccc;
  color: #fff;
}

// ---------------------------------------------------------------
// Footer
// ---------------------------------------------------------------
.footer {
  margin-top: 60px;
  padding: 20px 0;
  text-align: center;
  color: #999;
  font-size: 0.8125em;
}

.footer .with-love {
  margin: 0 5px;
}

.powered-by {
  margin-top: 10px;
}

// ---------------------------------------------------------------
// Back to Top
// ---------------------------------------------------------------
.back-to-top {
  background: var(--content-bg-color);
  bottom: 20px;
  box-shadow: 0 0 5px rgba(0, 0, 0, 0.1);
  opacity: 0;
  transition: opacity 0.3s;
}

.back-to-top.on {
  opacity: 1;
}

// ---------------------------------------------------------------
// Archive Page
// ---------------------------------------------------------------
.collection-title {
  font-size: 2em;
  margin-bottom: 30px;
}

.collection-year {
  margin: 30px 0;
}

.archive-post {
  padding: 10px 0;
  border-bottom: 1px solid #eee;
}

.archive-post-title {
  font-size: 1.2em;
}

.archive-post-date {
  color: #999;
  font-size: 0.875em;
}

// ---------------------------------------------------------------
# 404 Page
// ---------------------------------------------------------------
.error-page {
  text-align: center;
  padding: 100px 0;
}

.error-page .error-title {
  font-size: 5em;
  margin: 0;
}

.error-page .error-message {
  font-size: 1.5em;
  color: #999;
  margin: 20px 0;
}

// ---------------------------------------------------------------
// Tag & Category Pages
// ---------------------------------------------------------------
.tag-cloud {
  text-align: center;
  padding: 40px 0;
}

.tag-cloud-title {
  font-size: 1.5em;
  margin-bottom: 30px;
}

.tag-cloud-tags {
  font-size: 0;
}

.tag-cloud-tags a {
  display: inline-block;
  margin: 5px 10px;
  font-size: 1rem;
  border-bottom: none;
}

.tag-cloud-tags a:hover {
  background: var(--menu-item-bg-color);
}

// ---------------------------------------------------------------
// Search Modal
// ---------------------------------------------------------------
.search-pop-overlay {
  background: rgba(0, 0, 0, 0.3);
}

.search-popup {
  background: var(--content-bg-color);
  border-radius: 5px;
  box-shadow: 0 0 20px rgba(0, 0, 0, 0.2);
}

.search-input {
  border: none;
  font-size: 1.2em;
  padding: 10px;
  width: 100%;
}

.search-result {
  max-height: 400px;
  overflow-y: auto;
}

.search-result-title {
  font-size: 1.1em;
  margin: 10px 0 5px;
}

.search-result-title a {
  border-bottom: none;
}

.search-result-snippet {
  color: #999;
  font-size: 0.875em;
}

// ---------------------------------------------------------------
// Custom Effects Container
// ---------------------------------------------------------------
.fireworks {
  position: fixed;
  left: 0;
  top: 0;
  z-index: 9999;
  pointer-events: none;
}

.canvas-nest {
  position: fixed;
  left: 0;
  top: 0;
  z-index: -1;
}

// ---------------------------------------------------------------
// Responsive Adjustments
// ---------------------------------------------------------------
@media (max-width: 991px) {
  body {
    padding-left: 0 !important;
    padding-right: 0 !important;
  }
}

@media (max-width: 767px) {
  .site-title {
    font-size: 1.2em;
  }

  .site-subtitle {
    font-size: 0.75em;
  }

  .post-title {
    font-size: 1.3em;
  }

  .sidebar {
    display: none;
  }

  .main {
    width: 100%;
  }

  .footer {
    font-size: 0.75em;
  }
}
